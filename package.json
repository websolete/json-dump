{
  "name": "json-dump",
  "publisher": "EdgeInformation",
  "displayName": "JSON Dump",
  "description": "Renders .json documents in an interactive cfdump-style webview",
  "author": {
    "name": "Kevin Miller"
  },
  "license": "MIT",
  "version": "0.1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/websolete/json-dump.git"
  },
  "homepage": "https://github.com/websolete/json-dump#readme",
  "bugs": {
    "url": "https://github.com/websolete/json-dump/issues"
  },
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#17324d",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "json",
    "dump",
    "inspector",
    "viewer",
    "tree",
    "cfdump",
    "webview"
  ],
  "markdown": "github",
  "pricing": "Free",
  "extensionKind": [
    "ui"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "jsonDump.showDump",
        "title": "JSON Dump"
      },
      {
        "command": "jsonDump.sortAlpha",
        "title": "Sort Keys A→Z",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "jsonDump.sortNatural",
        "title": "Natural Key Order",
        "icon": "$(list-unordered)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "jsonDump.sortAlpha",
          "when": "activeWebviewPanelId == jsonDump && !jsonDump.isSortedAlpha",
          "group": "navigation"
        },
        {
          "command": "jsonDump.sortNatural",
          "when": "activeWebviewPanelId == jsonDump && jsonDump.isSortedAlpha",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "jsonDump.showDump",
          "when": "resourceExtname == .json",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "jsonDump.showDump",
          "when": "resourceExtname == .json",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "package:vsix": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "typescript": "^5.3.0"
  }
}
