{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "./schemas/application-metadata.schema.json",
  "title": "Copirate Application Metadata",
  "description": "Workspace-level application metadata used by Copirate to improve workspace purpose, runtime, framework, and language detection.",
  "type": "object",
  "required": [
    "runtimeTargets"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "workspacePurpose": {
            "const": "devops"
          }
        },
        "required": [
          "workspacePurpose"
        ]
      },
      "then": {
        "properties": {
          "runtimeTargets": {
            "minItems": 0
          }
        }
      },
      "else": {
        "properties": {
          "runtimeTargets": {
            "minItems": 1
          }
        }
      }
    }
  ],
  "definitions": {
    "runtimeTarget": {
      "type": "object",
      "required": [
        "engine"
      ],
      "properties": {
        "engine": {
          "type": "string",
          "description": "Runtime engine name, such as ColdFusion, Node.js, or Python."
        },
        "version": {
          "type": "string",
          "description": "Runtime version, such as 2021, 20.x, or 3.11."
        },
        "engineVariant": {
          "type": "string",
          "description": "Runtime distribution/variant, such as Lucee or Adobe CF."
        }
      },
      "additionalProperties": false
    }
  },
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional JSON schema URI for editor IntelliSense and validation."
    },
    "workspacePurpose": {
      "type": "string",
      "description": "High-level workspace purpose when the repository is not centered on a deployable application runtime.",
      "enum": [
        "application",
        "devops"
      ]
    },
    "runtimeTargets": {
      "type": "array",
      "description": "Declared runtime targets for this workspace. DevOps/tooling workspaces may leave this empty.",
      "items": {
        "$ref": "#/definitions/runtimeTarget"
      }
    },
    "frameworks": {
      "type": "array",
      "description": "Frameworks used by the application.",
      "items": {
        "type": "string"
      }
    },
    "databases": {
      "type": "array",
      "description": "Databases used by the application.",
      "items": {
        "type": "string"
      }
    },
    "languageHints": {
      "type": "array",
      "description": "Explicit language identifiers to guide Copirate language detection (e.g., cfml, javascript).",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "object",
      "description": "Key dependency versions not represented in package manager manifests.",
      "additionalProperties": {
        "type": "string"
      }
    },
    "notes": {
      "type": "string",
      "description": "Free-text implementation notes for maintainers."
    },
    "source": {
      "type": "string",
      "description": "Origin of this metadata file.",
      "enum": [
        "manual",
        "generated"
      ]
    },
    "generatedAt": {
      "type": "string",
      "description": "ISO-8601 timestamp when this file was generated."
    }
  },
  "additionalProperties": false
}
